# Mac system files
.DS_Store
.AppleDouble

# Python cache (auto-generated, not needed)
__pycache__/
*.pyc
*.pyo

# Secrets and credentials — never upload these
.env
*.env
secrets.py
credentials.py
.github_token
.gmail_password

# Personal Mac scheduler — contains your local file paths
com.altdata.pipeline.plist

# Pipeline logs — local only
data/pipeline_log.txt
data/launchd_out.log
data/launchd_err.log
data/previous_signals.json

# Local backups — never push these (can be several hundred MB)
backups/
